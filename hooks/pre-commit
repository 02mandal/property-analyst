#!/usr/bin/env python3
"""Pre-commit hook to run ruff and pyright checks."""

import subprocess
import sys


def main():
    """Run pre-commit checks."""
    print("=" * 50)
    print("Pre-commit checks")
    print("=" * 50)

    checks = [
        ("Ruff", ["poetry", "run", "ruff", "check", "."]),
        ("Pyright", ["poetry", "run", "pyright"]),
    ]

    all_passed = True

    for name, cmd in checks:
        print(f"\nRunning {name}...")
        result = subprocess.run(cmd)
        if result.returncode != 0:
            print(f"✗ {name} failed")
            all_passed = False
        else:
            print(f"✓ {name} passed")

    print("=" * 50)

    if all_passed:
        print("All checks passed ✓")
        sys.exit(0)
    else:
        print("Checks failed. Fix errors before committing.")
        sys.exit(1)


if __name__ == "__main__":
    main()
