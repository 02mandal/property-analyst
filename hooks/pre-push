#!/usr/bin/env python3
"""Pre-push hook to block direct pushes to main branch."""

import logging
import subprocess
import sys

logging.basicConfig(
    level=logging.INFO,
    format="%(message)s",
)
log = logging.getLogger(__name__)


def main():
    """Block direct pushes to protected branches."""
    protected = {"main", "master"}

    result = subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True,
        text=True,
    )
    current_branch = result.stdout.strip()

    if current_branch in protected:
        log.error("Blocked push to protected branch: %s", current_branch)
        log.info("Create a new branch: git checkout -b feature/your-feature")
        log.info("Commit and push: git push -u origin feature/your-feature")
        sys.exit(1)

    sys.exit(0)


if __name__ == "__main__":
    main()
